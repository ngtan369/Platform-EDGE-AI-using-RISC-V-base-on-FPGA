# =============================================================================
# OS / Editor
# =============================================================================
.DS_Store
Thumbs.db
desktop.ini
*~
*.swp
*.swo
.vscode/
.idea/
*.sublime-*

# =============================================================================
# Python (training/, host/edge_ai/, host/notebooks/)
# =============================================================================
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
.pytest_cache/
.mypy_cache/
.ruff_cache/
.tox/
.coverage
htmlcov/

# Virtual environments (anywhere in tree)
.venv/
venv/
env/
ENV/

# Jupyter
.ipynb_checkpoints/
*-checkpoint.ipynb

# =============================================================================
# Training artifacts (re-generated by training/train.py — pushed to KV260
# via host/scripts/deploy.sh, not committed)
# =============================================================================
training/export/
training/data/
training/datasets/
*.tflite
*.h5
*.ckpt
*.pb

# TensorFlow / Keras logs
logs/
**/tensorboard/

# =============================================================================
# RISC-V firmware build artifacts (firmware/)
# =============================================================================
firmware/*.o
firmware/*.d
firmware/*.elf
firmware/*.bin
firmware/*.hex
firmware/*.map
firmware/*.lst
firmware/*.dis

# NOTE: firmware/layer_table.h IS tracked — it pairs with the committed
# weights.bin / model snapshot so the firmware can be rebuilt from a fresh
# clone without re-running training.

# =============================================================================
# Vivado project (hw/vivado_pj/) — track only the .xpr and user RTL sources
# =============================================================================
hw/vivado_pj/*
!hw/vivado_pj/*.xpr
!hw/vivado_pj/vivado_pj.srcs/
hw/vivado_pj/vivado_pj.srcs/sources_1/imports/
hw/vivado_pj/vivado_pj.srcs/utils_1/
hw/vivado_pj/vivado_pj.srcs/**/ip/*/*.xci.bak

# Vivado runtime / generated dirs (anywhere under hw/)
**/.Xil/
**/*.cache/
**/*.runs/
**/*.sim/
**/*.hw/
**/*.gen/
**/*.tmp/
**/*.ip_user_files/

# Vivado log / journal noise
*.jou
*.log
*.str
*.backup.jou
*.backup.log
*.pb.jou
hbs.log
vivado_*.debug
vivado_pid*.zip

# Bitstream / hardware archive (release artifacts go in hw/artifacts/, not in vivado_pj/)
hw/vivado_pj/**/*.bit
hw/vivado_pj/**/*.xsa
hw/vivado_pj/**/*.ltx
hw/vivado_pj/**/*.bin

# =============================================================================
# Vivado IP packaging (hw/ip_repo/*) — track HDL/src + component.xml only
# =============================================================================
hw/ip_repo/*/.Xil/
hw/ip_repo/*/xgui/.cache/
hw/ip_repo/*/component_*/
hw/ip_repo/*/tmp_edit_*/

# =============================================================================
# OpenHW CV32E40P submodule (hw/cv32e40p/) — track RTL + bhv only
# =============================================================================
hw/cv32e40p/*
!hw/cv32e40p/rtl/
!hw/cv32e40p/bhv/
!hw/cv32e40p/constraints/
!hw/cv32e40p/README.md
!hw/cv32e40p/LICENSE
!hw/cv32e40p/CITATION.cff

# =============================================================================
# Secrets / local config
# =============================================================================
.env
.env.*
!.env.example
*.pem
*.key
secrets.json
.claude/settings.local.json

# =============================================================================
# Misc
# =============================================================================
*.bak
*.orig
*.rej
*.tmp
*.zip
*.tar
*.tar.gz
node_modules/
